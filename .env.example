# =============================================================================
# HeySalad AI Agent — Environment Variables
# =============================================================================

# Database (Neon Postgres recommended)
DATABASE_URL="postgresql://user:password@host:5432/heysalad_agent?sslmode=require"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth
AUTH_SESSION_SECRET="replace-with-a-long-random-secret"
AGENT_API_KEY="your-agent-api-key"

# ---------------------------------------------------------------------------
# AI Providers (at least one required)
# ---------------------------------------------------------------------------

# OpenAI (default)
OPENAI_API_KEY=""
AI_MODEL="openai/gpt-4o"

# Azure OpenAI (alternative)
# AZURE_OPENAI_ENDPOINT=""
# AZURE_OPENAI_API_KEY=""
# AZURE_OPENAI_DEPLOYMENT="gpt-4o"

# Hugging Face (alternative)
# HUGGINGFACE_API_KEY=""

# Anthropic (alternative)
# ANTHROPIC_API_KEY=""

# ---------------------------------------------------------------------------
# Communication
# ---------------------------------------------------------------------------

# Twilio (voice + SMS)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Resend (email)
RESEND_API_KEY=""

# ElevenLabs (voice synthesis — optional)
# ELEVENLABS_API_KEY=""
# ELEVENLABS_VOICE_ID=""

# ---------------------------------------------------------------------------
# Payments (at least one for billing features)
# ---------------------------------------------------------------------------

# Stripe (default)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Airwallex (alternative)
# AIRWALLEX_CLIENT_ID=""
# AIRWALLEX_API_KEY=""
# AIRWALLEX_API_URL="https://api-demo.airwallex.com/api/v1"

# PayPal (alternative)
# PAYPAL_CLIENT_ID=""
# PAYPAL_SECRET=""
# PAYPAL_API_URL="https://api-m.sandbox.paypal.com"

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET=""

# ---------------------------------------------------------------------------
# Feature Flags (all default to false)
# ---------------------------------------------------------------------------

# Provider selection
HEYSALAD_PAYMENT_PROVIDER="stripe"
HEYSALAD_VOICE_PROVIDER="twilio"
HEYSALAD_MODEL_PROVIDER="openai"

# Eve agent framework
HEYSALAD_EVE_ENABLED="false"

# OpenAI extended features
HEYSALAD_OPENAI_RESPONSES="false"
HEYSALAD_OPENAI_REALTIME="false"
HEYSALAD_OPENAI_IMAGES="false"

# Marketplace
HEYSALAD_CORALOS_ENABLED="false"
HEYSALAD_SOLANA_ENABLED="false"

# Additional providers
HEYSALAD_MICROSOFT_ENABLED="false"
HEYSALAD_FETCHAI_ENABLED="false"
HEYSALAD_ELEVENLABS_ENABLED="false"
HEYSALAD_HUGGINGFACE_ENABLED="false"
HEYSALAD_AIRWALLEX_ENABLED="false"
HEYSALAD_PAYPAL_ENABLED="false"
